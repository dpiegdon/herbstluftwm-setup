From 11e11dba75e89b3dacaa3e6eabb8128096a95bdb Mon Sep 17 00:00:00 2001
From: "David R. Piegdon" <dgit@piegdon.de>
Date: Wed, 10 Jun 2026 22:33:08 +0000
Subject: [PATCH] Drop EnterNotify events after cross-monitor pointer warp

When an EnterNotify event for a window on another monitor is processed
while the pointer is no longer over that window (e.g. because the
pointer quickly crossed the monitor boundary and back, queueing two
stale crossing events), enternotify() switches the monitor and
monitor_focus_by_index() warps the pointer to the other monitor. The
artificial EnterNotify events generated by this warp are supposed to be
dropped right after XWarpPointer(), but the drop is a no-op: since
commit 62121a9e, XMainLoop::dropEnterNotifyEvents() returns without
dropping anything while an EnterNotify event is being handled.

That commit assumed that during enternotify() handling "only the focus
is changed", which does not hold for cross-monitor focus changes: both
monitors are re-layouted and the pointer is warped, all while
duringEnterNotify_ is true.

As a consequence, each warp-generated event is processed later, when
the pointer has already been warped away again by the next stale event
in the queue. This re-triggers the monitor switch and pointer warp in
the opposite direction, and every warp replenishes the queue with a
fresh stale event: the pointer warps between two monitors in an
endless high-frequency oscillation that can only be stopped by a
button press (whose passive grab makes enternotify() ignore the
crossing events).

Fix this by giving the dropEnterNotifyEvents signal a 'force'
parameter, set to true for the drop after XWarpPointer(): after a
pointer warp, all queued EnterNotify events refer to outdated pointer
positions, so dropping them even during enternotify() handling is
correct and breaks the feedback loop. The drops after re-layouting
remain non-forced, so the behavior introduced by 62121a9e for #908
(quick movements across windows on the same monitor must not lose
enter events) is preserved; its test cases still pass.

Add a regression test that reproduces the oscillation by queueing two
stale cross-monitor EnterNotify events while hlwm is suspended.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 src/monitor.cpp            | 13 +++++++---
 src/monitormanager.cpp     |  2 +-
 src/monitormanager.h       |  9 ++++++-
 src/xmainloop.cpp          | 13 +++++++---
 src/xmainloop.h            |  2 +-
 tests/test_basic_events.py | 50 ++++++++++++++++++++++++++++++++++++++
 6 files changed, 79 insertions(+), 10 deletions(-)

diff --git a/src/monitor.cpp b/src/monitor.cpp
index 2a3e6071..92607d80 100644
--- a/src/monitor.cpp
+++ b/src/monitor.cpp
@@ -281,7 +281,7 @@ void Monitor::applyLayout() {
 
     // remove all enternotify-events from the event queue that were
     // generated while arranging the clients on this monitor
-    monman->dropEnterNotifyEvents.emit();
+    monman->dropEnterNotifyEvents.emit(false);
 }
 
 Monitor* find_monitor_by_name(const char* name) {
@@ -498,7 +498,7 @@ int monitor_set_tag(Monitor* monitor, HSTag* tag) {
     old_tag->setVisible(false);
     // focus window just has been shown
     // discard enternotify-events
-    g_monitors->dropEnterNotifyEvents.emit();
+    g_monitors->dropEnterNotifyEvents.emit(false);
     monitor_update_focus_objects();
     Ewmh::get().updateCurrentDesktop();
     emit_tag_changed(tag, g_monitors->cur_monitor);
@@ -557,8 +557,13 @@ void monitor_focus_by_index(unsigned new_selection) {
         XWarpPointer(g_display, None, g_root, 0, 0, 0, 0, new_x, new_y);
         // discard all mouse events caused by this pointer movage from the
         // event queue, so the focus really stays in the last focused window on
-        // this monitor and doesn't jump to the window hovered by the mouse
-        g_monitors->dropEnterNotifyEvents.emit();
+        // this monitor and doesn't jump to the window hovered by the mouse.
+        // The drop must also happen if this monitor switch was triggered
+        // from within enternotify() (force = true): after the pointer warp,
+        // all queued EnterNotify events refer to outdated pointer positions
+        // and processing them would warp the pointer back and forth between
+        // the monitors in an endless loop.
+        g_monitors->dropEnterNotifyEvents.emit(true);
     }
     // update objects
     monitor_update_focus_objects();
diff --git a/src/monitormanager.cpp b/src/monitormanager.cpp
index ac820db9..99c38789 100644
--- a/src/monitormanager.cpp
+++ b/src/monitormanager.cpp
@@ -421,7 +421,7 @@ void MonitorManager::addMonitorCommand(CallOrComplete invoc)
         monitor->applyLayout();
         tag->setVisible(true);
         emit_tag_changed(tag, static_cast<int>(monitor->index()));
-        dropEnterNotifyEvents.emit();
+        dropEnterNotifyEvents.emit(false);
         return HERBST_EXIT_SUCCESS;
     });
 }
diff --git a/src/monitormanager.h b/src/monitormanager.h
index 00084cdc..0dca262b 100644
--- a/src/monitormanager.h
+++ b/src/monitormanager.h
@@ -110,8 +110,15 @@ public:
      * @brief this signal is emitted whenever the mouse cursor have
      * entered another window although the user has not moved the cursor
      * manually. In this case the respective events have to be ignored.
+     * The bool parameter says whether the events must be dropped even
+     * if we are currently processing an EnterNotify event: this is
+     * required after XWarpPointer(), because the pointer warp makes all
+     * EnterNotify events in the queue refer to outdated pointer
+     * positions; processing them would re-trigger monitor switches and
+     * thus pointer warps, resulting in an endless warp oscillation
+     * between monitors.
      */
-    Signal dropEnterNotifyEvents;
+    Signal_<bool> dropEnterNotifyEvents;
 
 private:
     std::function<int(Input, Output)> byFirstArg(MonitorCommand cmd);
diff --git a/src/xmainloop.cpp b/src/xmainloop.cpp
index b740d5e6..eaed2c48 100644
--- a/src/xmainloop.cpp
+++ b/src/xmainloop.cpp
@@ -236,13 +236,20 @@ void XMainLoop::quit() {
     aboutToQuit_ = true;
 }
 
-void XMainLoop::dropEnterNotifyEvents()
+void XMainLoop::dropEnterNotifyEvents(bool force)
 {
-    if (duringEnterNotify_) {
-        // during a enternotify(), no artificial enter notify events
+    if (duringEnterNotify_ && !force) {
+        // during a enternotify(), usually no artificial enter notify events
         // can be created. Moreover, on quick mouse movements, an enter notify
         // might be followed by further enter notify events, which
         // must not be dropped.
+        //
+        // However, if enternotify() triggers a monitor switch, then
+        // XWarpPointer() *does* create artificial enter notify events.
+        // These must be dropped (force = true), because otherwise they
+        // are processed with the pointer already warped away, which
+        // triggers another monitor switch and warp, resulting in an
+        // endless warp oscillation between the monitors.
         return;
     }
     XEvent ev;
diff --git a/src/xmainloop.h b/src/xmainloop.h
index e6898776..0fc15abb 100644
--- a/src/xmainloop.h
+++ b/src/xmainloop.h
@@ -24,7 +24,7 @@ public:
     //! a child process exited with the given status
     Signal_<std::pair<pid_t, int>> childExited;
 
-    void dropEnterNotifyEvents();
+    void dropEnterNotifyEvents(bool force);
 private:
     // members
     XConnection& X_;
diff --git a/tests/test_basic_events.py b/tests/test_basic_events.py
index cb3b4e50..d06649e1 100644
--- a/tests/test_basic_events.py
+++ b/tests/test_basic_events.py
@@ -1,5 +1,7 @@
 import pytest
+import signal
 import test_stack
+import time
 import Xlib
 
 
@@ -146,6 +148,54 @@ def test_enternotify_do_not_drop_events(hlwm, mouse, client_count):
     assert hlwm.get_attr('clients.focus.winid') == winid[client_count - 1]
 
 
+def test_no_warp_oscillation_between_monitors(hlwm, hlwm_process, mouse):
+    """when two stale EnterNotify events for windows on different monitors
+    are in the event queue, the pointer must not enter an endless warp
+    oscillation between the monitors: processing the first event switches
+    the monitor and warps the pointer, and the resulting artificial
+    EnterNotify events must not switch the monitor back again.
+    """
+    hlwm.call('set focus_follows_mouse on')
+    hlwm.call('add othertag')
+    hlwm.call('set_monitors 400x600+0+0 400x600+400+0')
+    # one client on each monitor
+    win_a, _ = hlwm.create_client()
+    hlwm.call('focus_monitor 1')
+    win_b, _ = hlwm.create_client()
+    # park the pointer inside win_b before leaving monitor 1, such that
+    # monitor 1's saved mouse position (= the destination of later pointer
+    # warps to monitor 1) is over win_b. Otherwise the warp would land on
+    # the root window, where no further EnterNotify processing happens.
+    mouse.move_into(win_b, 100, 100)
+    hlwm.call('focus_monitor 0')
+    mouse.move_into(win_a, 100, 100)
+    assert hlwm.get_attr('clients.focus.winid') == win_a
+    assert hlwm.get_attr('monitors.focus.index') == '0'
+
+    # create two stale EnterNotify events: move the pointer into the
+    # window on the other monitor and back, while hlwm is suspended and
+    # cannot process the events in between. So hlwm will process the
+    # EnterNotify for win_b while the pointer is back on win_a already.
+    hlwm_process.proc.send_signal(signal.SIGSTOP)
+    try:
+        mouse.move_into(win_b, 100, 100, wait=False)
+        mouse.move_into(win_a, 100, 100, wait=False)
+    finally:
+        hlwm_process.proc.send_signal(signal.SIGCONT)
+
+    # the focused monitor must converge: hlwm processes the EnterNotify
+    # for win_b, switches to monitor 1 and warps the pointer there. The
+    # pointer warp must drop the second stale event (for win_a), so no
+    # further monitor switch may happen afterwards.
+    samples = []
+    for _ in range(20):
+        samples.append(hlwm.get_attr('monitors.focus.index'))
+        time.sleep(0.05)
+    # allow the first samples to differ while hlwm processes the queue,
+    # but then the focused monitor must stay stable:
+    assert len(set(samples[5:])) == 1
+
+
 def test_no_map_of_visible_unmanaged_windows(hlwm, hc_idle, x11):
     hlwm.call(['rule', 'hook=tempmanage'])
     x11.pop_pending_events()  # clear event queue
